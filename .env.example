# Database configuration
# ---------------------
# Option 1 (default): SQLite – zero setup, DB file created automatically
# DATABASE_PATH=face_recognition.db

# Option 2: PostgreSQL – uncomment and set your connection string
# DATABASE_URL=postgresql://face_app:face_app_dev@localhost:5432/face_recognition

# Visit tracking
# VISIT_TIMEOUT_MINUTES=10
# VISIT_TRANSITION_SECS=2.0

# Master AI switch — set to false to disable all face detection, recognition,
# tracking, and attendance. The system becomes a plain camera stream viewer.
# FACE_DETECTION_ENABLED=true

# Action detection (CLIP zero-shot) — set to false to disable
# ACTION_DETECTION_ENABLED=false

# Auto-capture unknowns — saves face crops of unrecognised people
# Best for small crowds; disable for large/public spaces
# AUTO_CAPTURE_ENABLED=false

# Live MJPEG annotations — bounding boxes + name labels on the live feed.
# Default on. Set to false for a clean live stream when scenes are
# crowded and overlapping boxes become illegible. Footage clips are
# always annotated regardless of this flag.
# LIVE_ANNOTATIONS_ENABLED=true

# GPU-side RTSP video decode (NVDEC). Default on. Set to false to force
# CPU decode for debugging or non-NVIDIA hosts.
# USE_NVDEC=true

# Public API access
# ---------------------
# When API_KEY is set, every /api/* and stream route requires the same key
# (header X-API-Key, or ?api_key=... query for streams/img tags). Leave
# unset for local-only development. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# API_KEY=

# Network storage — footage is written here instead of locally.
# Mount the share before starting the app (cifs-utils required):
#   sudo mount -t cifs //NAS_HOST/SHARE /mnt/camera_system \
#     -o username=USER,password=PASS,uid=$(id -u),gid=$(id -g),file_mode=0775,dir_mode=0775
# Then create the subdirectory: mkdir -p /mnt/camera_system/footage
# NAS credentials (used in mount command — not read by the app directly)
# NAS_HOST=192.168.x.x
# NAS_SHARE=server/camera_system
# NAS_USER=your_nas_username
# NAS_PASS=your_nas_password
FOOTAGE_DIR=/mnt/camera_system/footage