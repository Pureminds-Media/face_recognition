# Database configuration
# ---------------------
# Option 1 (default): SQLite – zero setup, DB file created automatically
# DATABASE_PATH=face_recognition.db

# Option 2: PostgreSQL – uncomment and set your connection string
# DATABASE_URL=postgresql://face_app:face_app_dev@localhost:5432/face_recognition

# Visit tracking
# VISIT_TIMEOUT_MINUTES=10
# VISIT_TRANSITION_SECS=2.0

# Action detection (CLIP zero-shot) — set to false to disable
# ACTION_DETECTION_ENABLED=false

# Auto-capture unknowns — saves face crops of unrecognised people
# Best for small crowds; disable for large/public spaces
# AUTO_CAPTURE_ENABLED=false
